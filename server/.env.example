# ============================================================
# Golden Beach Resort — server configuration
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env to source control.
# ============================================================

# --- App ---
NODE_ENV=production
PORT=3000

# A long random string used to sign session cookies.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# --- SQL Server ---
DB_HOST=localhost
DB_PORT=1433
DB_NAME=goldenbeach
DB_USER=sa
DB_PASS="red sea sql"

# TLS for the database connection.
# encrypt=true keeps traffic encrypted in transit (recommended).
# If your SQL Server uses a self-signed certificate, set trust=true.
# With a proper CA-signed certificate, leave trust=false.
DB_ENCRYPT=false
DB_TRUST_CERT=true
